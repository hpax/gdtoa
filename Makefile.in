CC	= @CC@
CFLAGS	= @CFLAGS@
LDFLAGS	= @LDFLAGS@

AR	= @AR@
RANLIB	= @RANLIB@

O	= @OBJEXT@
A	= @LIBEXT@
X	= @EXEEXT@

.SUFFIXES: .c .h .$(O) .$(A) $(X)

.c.$(O):
	$(CC) $(CFLAGS) -c -o $@ $<

.$(O)$(X):
	$(CC) $(LDFLAGS) -o $@ $<

LIB		= gdtoa.$(A)
LIB_PRINTF	= gdtoa_printf.$(A)

HEADERS	= gdtoa.h gdtoa_fltrnds.h gdtoaimp.h stdio1.h
GENHDRS = gdtoacfg.h arith.h gd_qnan.h
ALLHDRS = $(HEADERS) $(GENHDRS)

all: $(LIB) $(LIB_PRINTF)

# --- Replace these with something that supports cross-compilation, and/or
# --- remove obsolete features...
arith.h: arithchk$(X)
	./arithchk$(X) > arith.h

gd_qnan.h: qnan$(X)
	./qnan$(X) > gd_qnan.h

LIBOBJ = \
	dmisc.$(O) \
	dtoa.$(O) \
	g_Qfmt.$(O) \
	g_Qfmt_p.$(O) \
	g__fmt.$(O) \
	g_ddfmt.$(O) \
	g_ddfmt_p.$(O) \
	g_dfmt.$(O) \
	g_dfmt_p.$(O) \
	g_ffmt.$(O) \
	g_ffmt_p.$(O) \
	g_xLfmt.$(O) \
	g_xLfmt_p.$(O) \
	g_xfmt.$(O) \
	g_xfmt_p.$(O) \
	gdtoa.$(O) \
	gethex.$(O) \
	gmisc.$(O) \
	hd_init.$(O) \
	hexnan.$(O) \
	misc.$(O) \
	smisc.$(O) \
	strtoIQ.$(O) \
	strtoId.$(O) \
	strtoIdd.$(O) \
	strtoIf.$(O) \
	strtoIg.$(O) \
	strtoIx.$(O) \
	strtoIxL.$(O) \
	strtod.$(O) \
	strtodI.$(O) \
	strtodg.$(O) \
	strtof.$(O) \
	strtopQ.$(O) \
	strtopd.$(O) \
	strtopdd.$(O) \
	strtopf.$(O) \
	strtopx.$(O) \
	strtopxL.$(O) \
	strtorQ.$(O) \
	strtord.$(O) \
	strtordd.$(O) \
	strtorf.$(O) \
	strtorx.$(O) \
	strtorxL.$(O) \
	sum.$(O) \
	ulp.$(O)

$(LIB): $(LIBOBJ)
	rm -f $(LIB)
	$(AR) cq $(LIB) $(LIBOBJ)
	$(RANLIB) $(LIB)

$(LIB_PRINTF): $(LIBOBJ) $(LIBOBJ_PRINTF)
	rm -f $(LIB_PRINTF)
	$(AR) cq $(LIB_PRINTF) $(LIBOBJ) $(LIBOBJ_PRINTF)
	$(RANLIB) $(LIB_PRINTF)

clean:
	rm -f *.$(O) *.$(A) arithchk$(X) qnan$(X)

dmisc.$(O): $(ALLHDRS)
dtoa.$(O): $(ALLHDRS)
g_Qfmt.$(O): $(ALLHDRS)
g_Qfmt_p.$(O): $(ALLHDRS)
g__fmt.$(O): $(ALLHDRS)
g_ddfmt.$(O): $(ALLHDRS)
g_ddfmt_p.$(O): $(ALLHDRS)
g_dfmt.$(O): $(ALLHDRS)
g_dfmt_p.$(O): $(ALLHDRS)
g_ffmt.$(O): $(ALLHDRS)
g_ffmt_p.$(O): $(ALLHDRS)
g_xLfmt.$(O): $(ALLHDRS)
g_xLfmt_p.$(O): $(ALLHDRS)
g_xfmt.$(O): $(ALLHDRS)
g_xfmt_p.$(O): $(ALLHDRS)
gdtoa.$(O): $(ALLHDRS)
gethex.$(O): $(ALLHDRS)
gmisc.$(O): $(ALLHDRS)
hd_init.$(O): $(ALLHDRS)
hexnan.$(O): $(ALLHDRS)
misc.$(O): $(ALLHDRS)
smisc.$(O): $(ALLHDRS)
strtoIQ.$(O): $(ALLHDRS)
strtoId.$(O): $(ALLHDRS)
strtoIdd.$(O): $(ALLHDRS)
strtoIf.$(O): $(ALLHDRS)
strtoIg.$(O): $(ALLHDRS)
strtoIx.$(O): $(ALLHDRS)
strtoIxL.$(O): $(ALLHDRS)
strtod.$(O): $(ALLHDRS)
strtodI.$(O): $(ALLHDRS)
strtodg.$(O): $(ALLHDRS)
strtof.$(O): $(ALLHDRS)
strtopQ.$(O): $(ALLHDRS)
strtopd.$(O): $(ALLHDRS)
strtopdd.$(O): $(ALLHDRS)
strtopf.$(O): $(ALLHDRS)
strtopx.$(O): $(ALLHDRS)
strtopxL.$(O): $(ALLHDRS)
strtorQ.$(O): $(ALLHDRS)
strtord.$(O): $(ALLHDRS)
strtordd.$(O): $(ALLHDRS)
strtorf.$(O): $(ALLHDRS)
strtorx.$(O): $(ALLHDRS)
strtorxL.$(O): $(ALLHDRS)
sum.$(O): $(ALLHDRS)
ulp.$(O): $(ALLHDRS)
arithckh.$(O): gdtoacfg.h
qnan.$(O): gdtoacfg.h arith.h
